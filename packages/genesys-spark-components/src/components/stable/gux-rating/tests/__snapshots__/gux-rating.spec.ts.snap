  <template shadowrootmode="open">
    <div class="gux-compact gux-rating-star-container">
      <div class="gux-star-rating-compact">
        <div class="gux-star-rating-label-value">
          <gux-icon decorative="" icon-name="fa/star-regular" size="small" tabindex="0"></gux-icon>
          <span class="gux-star-rating-value">
            0
          </span>
