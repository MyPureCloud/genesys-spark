        <div class="gux-edit-rating-button">
          <gux-button accent="inline" id="popover-target" tabindex="-1">
            Edit Rating
          </gux-button>
          <gux-popover-beta for="popover-target" position="bottom-start">
            <gux-rating aria-label="Feedback" aria-readonly="false" aria-valuemax="5" aria-valuemin="0" aria-valuenow="0" max-value="5" role="spinbutton" tabindex="0">
